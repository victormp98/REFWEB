@model IEnumerable<RefWeb.Models.Direccion>
@{
    ViewData["Title"] = "Libreta de Direcciones";
}

@section Breadcrumbs {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb breadcrumb-modern">
            <li class="breadcrumb-item"><a asp-area="Tienda" asp-controller="Tienda" asp-action="Index">Tienda</a></li>
            <li class="breadcrumb-item active" aria-current="page">Mis Direcciones</li>
        </ol>
    </nav>
}

<div class="animate-fade-in mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Mis Direcciones</h2>
            <p class="text-muted mb-0">Administra tus lugares de entrega frecuentes.</p>
        </div>
        <button class="btn btn-primary rounded-pill fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNuevaDireccion">
            <i class="fas fa-plus me-1"></i> Nueva Dirección
        </button>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 py-5 text-center bg-white rounded-4 shadow-sm">
                <i class="fas fa-map-marked-alt fa-4x text-muted opacity-25 mb-3 d-block"></i>
                <h5 class="fw-bold">Sin Direcciones</h5>
                <p class="text-muted mb-0">Aún no has guardado ninguna dirección de envío.</p>
            </div>
        }
        else
        {
            @foreach (var dir in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card card-modern h-100 border-0 shadow-sm @(dir.EsPrincipal ? "border-primary-soft shadow-lg border-2" : "")">
                        <div class="card-body p-4 position-relative">
                            @if (dir.EsPrincipal)
                            {
                                <span class="position-absolute top-0 end-0 badge bg-primary m-3 rounded-pill shadow-sm">
                                    <i class="fas fa-star text-warning me-1"></i> Predeterminada
                                </span>
                            }
                            
                            <h5 class="fw-bold mb-1">
                                <i class="fas fa-@(dir.TipoDireccion == "Oficina" ? "building" : "home") text-secondary me-2"></i>@dir.TipoDireccion
                            </h5>
                            <hr class="border-light">
                            <p class="mb-1 text-dark fw-bold">@dir.Calle</p>
                            <p class="mb-1 text-muted small">Col. @dir.Colonia</p>
                            <p class="mb-3 text-muted small">@dir.Ciudad, @dir.Estado. CP. @dir.CodigoPostal</p>
                            
                            @if (!string.IsNullOrEmpty(dir.Referencias))
                            {
                                <div class="bg-light p-2 rounded small text-muted fst-italic mb-3">
                                    Ref: @dir.Referencias
                                </div>
                            }

                            <div class="d-flex justify-content-between mt-auto pt-3 border-top border-light">
                                @if (!dir.EsPrincipal)
                                {
                                    <form asp-action="MarcarPrincipal" asp-route-id="@dir.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill border-0 fw-bold">
                                            Hacer principal
                                        </button>
                                    </form>
                                }
                                <form asp-action="EliminarDireccion" asp-route-id="@dir.Id" method="post" onsubmit="return confirm('¿Eliminar dirección?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill border-0">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Modal Nueva Dirección -->
<div class="modal fade" id="modalNuevaDireccion" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Agregar Dirección</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="NuevaDireccion" method="post">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Etiqueta (Casa, Oficina...)</label>
                            <input type="text" name="TipoDireccion" class="form-control form-control-modern" required value="Casa" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Calle y Número</label>
                            <input type="text" name="Calle" class="form-control form-control-modern" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Colonia</label>
                            <input type="text" name="Colonia" class="form-control form-control-modern" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Código Postal</label>
                            <input type="text" name="CodigoPostal" class="form-control form-control-modern" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Ciudad</label>
                            <input type="text" name="Ciudad" class="form-control form-control-modern" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Estado</label>
                            <input type="text" name="Estado" class="form-control form-control-modern" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Referencias (opcional)</label>
                            <textarea name="Referencias" class="form-control form-control-modern" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">Guardar Dirección</button>
                </div>
            </form>
        </div>
    </div>
</div>
