@model IEnumerable<RefWeb.Models.Producto>
@{
    ViewData["Title"] = "Tienda Online";
}

<!-- Hero Section with Glassmorphism Overlay -->
<div class="position-relative py-5 mb-5 overflow-hidden" style="min-height: 400px; background: url('https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&q=80&w=2000') center/cover;">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>
    <div class="container position-relative z-index-1 h-100 d-flex flex-column justify-content-center text-center text-white py-5">
        <h1 class="display-3 fw-bold mb-3 animate-fade-in" style="font-family: 'Outfit', sans-serif;">Refaccionaria Web</h1>
        <p class="lead mb-4 animate-fade-in" style="animation-delay: 0.1s;">Encuentra las mejores refacciones con envío a todo México</p>
        <div class="d-flex justify-content-center gap-3 animate-fade-in" style="animation-delay: 0.2s;">
            <a href="#catalogo" class="btn btn-primary btn-lg px-5">Explorar Catálogo</a>
            <a href="/Identity/Account/Login" class="btn btn-outline-light btn-lg px-5 border-2">Mi Cuenta</a>
        </div>
    </div>
</div>

<div class="container mb-5" id="catalogo">
    <div class="row g-4">
        <!-- Sidebar Filtros -->
        <aside class="col-lg-3">
            <div class="glass-card p-4 sticky-top" style="top: 100px;">
                <h5 class="fw-bold mb-4 d-flex align-items-center">
                    <i class="fas fa-filter text-primary me-2"></i> Filtros
                </h5>
                
                <h6 class="fw-bold mb-3 small text-uppercase letter-spacing-1">Categorías</h6>
                <div class="d-flex flex-column gap-2">
                    <a href="@Url.Action("Index")" class="nav-link @(ViewBag.CategoriaSeleccionada == null ? "active" : "")">
                        <i class="fas fa-th-large me-2"></i> Todas
                    </a>
                    @foreach (var cat in ViewBag.Categorias)
                    {
                        <a href="@Url.Action("Index", new { categoriaId = cat.Id })" 
                           class="nav-link @(ViewBag.CategoriaSeleccionada == cat.Id ? "active" : "")">
                            <i class="fas fa-chevron-right me-2 small opacity-50"></i> @cat.Nombre
                        </a>
                    }
                </div>
                
                <hr class="my-4 opacity-10">
                
                <div class="bg-primary-soft p-3 rounded-3">
                    <p class="small text-dark mb-0 fw-600">
                        <i class="fas fa-shipping-fast me-2"></i>
                        Envío gratis en compras mayores a $2,500
                    </p>
                </div>
            </div>
        </aside>

        <!-- Catálogo -->
        <main class="col-lg-9">
            <div class="animate-fade-in">
                <!-- Search Section -->
                <div class="glass-card p-4 mb-5">
                    <div class="row align-items-center">
                        <div class="col-md-7">
                            <h4 class="fw-bold text-dark mb-1">Encuentra la refacción ideal</h4>
                            <p class="text-muted small mb-0">Explora nuestro catálogo de autopartes de alta calidad.</p>
                        </div>
                        <div class="col-md-5 mt-3 mt-md-0">
                            <form method="get" asp-action="Index" class="input-group">
                                @if (ViewBag.CategoriaSeleccionada != null)
                                {
                                    <input type="hidden" name="categoriaId" value="@ViewBag.CategoriaSeleccionada" />
                                }
                                <span class="input-group-text bg-transparent border-end-0 text-muted ps-3">
                                    <i class="fas fa-search"></i>
                                </span>
                                <input type="text" name="busqueda" value="@ViewBag.Busqueda"
                                       class="form-control border-start-0 shadow-none"
                                       placeholder="¿Qué estás buscando?..." />
                                <button type="submit" class="btn btn-primary">Buscar</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Product Grid -->
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="glass-card product-card d-flex flex-column h-100 overflow-hidden">
                                <div class="position-relative bg-light p-4 text-center" style="height: 220px;">
                                    <a asp-action="Detalle" asp-route-id="@item.Id" class="d-block w-100 h-100 text-decoration-none">
                                        @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                        {
                                            <img src="@item.ImagenUrl" class="w-100 h-100 object-fit-contain transition-transform duration-300" alt="@item.Nombre">
                                        }
                                        else
                                        {
                                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                                                <i class="fas fa-tools fa-4x opacity-10"></i>
                                            </div>
                                        }
                                    </a>
                                    
                                    @if (item.Stock <= 0)
                                    {
                                        <div class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex align-items-center justify-content-center pointer-events-none">
                                            <span class="badge bg-danger">Agotado</span>
                                        </div>
                                    }
                                    
                                    <span class="position-absolute top-0 end-0 m-3 badge bg-primary-soft pointer-events-none">
                                        @item.Categoria?.Nombre
                                    </span>
                                </div>

                                <div class="card-body p-4 d-flex flex-column">
                                    <a asp-action="Detalle" asp-route-id="@item.Id" class="text-decoration-none">
                                        <h5 class="fw-bold text-dark mb-2">@item.Nombre</h5>
                                    </a>
                                    <p class="text-muted small mb-4 flex-grow-1">@item.Descripcion</p>
                                    
                                    <div class="d-flex align-items-end justify-content-between">
                                        <div>
                                            <span class="text-muted x-small d-block text-uppercase fw-bold letter-spacing-1 mb-1">Precio</span>
                                            <span class="product-price">$@item.Precio.ToString("N2")</span>
                                        </div>
                                        @if (!(User.IsInRole("Admin") || User.IsInRole("Gerente")))
                                        {
                                            <button class="btn btn-primary rounded-circle p-0" 
                                                    style="width: 45px; height: 45px;"
                                                    onclick="CartManager.add(@item.Id, '@item.Nombre.Replace("'", "\\'")', @item.Precio, '@(item.ImagenUrl ?? "")')"
                                                    title="Añadir al carrito">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <!-- Paginación -->
                @if (ViewBag.TotalPaginas > 1)
                {
                    <nav class="mt-5">
                        <ul class="pagination justify-content-center gap-2">
                            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                            {
                                <li class="page-item @(ViewBag.PaginaActual == i ? "active" : "")">
                                    <a class="page-link border-0 rounded-3 shadow-sm px-3 @(ViewBag.PaginaActual == i ? "bg-primary text-white" : "bg-white text-dark")" 
                                       href="@Url.Action("Index", new { categoriaId = ViewBag.CategoriaSeleccionada, pagina = i })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </main>
    </div>
</div>

<style>
    .letter-spacing-1 { letter-spacing: 1.5px; }
    .z-index-1 { z-index: 1; }
    .nav-link.active { font-weight: 700; color: var(--primary) !important; background: rgba(79, 70, 229, 0.08); }
</style>

@section Scripts {
    <script>
    $(document).ready(function() {
        CartManager.updateBadge();

        // ── Notificación de Compra Exitosa (Strip/Webpay/Transferencia) ──
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('pago') === 'exito') {
            Swal.fire({
                icon: 'success',
                title: '¡Pedido Confirmado!',
                html: 'Tu pago se procesó correctamente y tu pedido ya está en preparación.<br><br><small class="text-muted">Te hemos enviado un correo con los detalles.</small>',
                confirmButtonText: 'Ver mis pedidos',
                showCancelButton: true,
                cancelButtonText: 'Seguir comprando',
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#6c757d',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Tienda/Tienda/MisPedidos';
                }
            });

            // Limpiar la URL para que no vuelva a salir al recargar
            const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
            window.history.replaceState({path: newUrl}, '', newUrl);
        }
    });
    </script>
}
