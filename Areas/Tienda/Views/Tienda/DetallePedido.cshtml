@model RefWeb.Models.Pedido
@{
    ViewData["Title"] = "Detalle del Pedido #" + Model.Id;
}

<div class="container my-5">
    <div class="mb-4 mt-5">
        <a href="@Url.Action("MisPedidos")" class="text-decoration-none"><i class="fas fa-arrow-left me-2"></i>Volver a mis pedidos</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Productos en este pedido</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Producto</th>
                                <th class="text-center">Precio</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end pe-4">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Detalles)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Producto?.ImagenUrl" class="rounded me-3" style="width: 50px; height: 50px; object-fit: contain;">
                                            <div>
                                                <h6 class="mb-0 fw-bold">@item.Producto?.Nombre</h6>
                                                <small class="text-muted">@item.Producto?.CodigoSKU</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">$@item.PrecioUnitario.ToString("N2")</td>
                                    <td class="text-center">@item.Cantidad</td>
                                    <td class="text-end pe-4 fw-bold">$@item.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-map-marker-alt text-danger me-2"></i>Dirección de Entrega</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1 fw-bold">@Model.DireccionEntrega?.Calle</p>
                    <p class="mb-1 text-muted">@Model.DireccionEntrega?.Colonia</p>
                    <p class="mb-0 text-muted">@Model.DireccionEntrega?.Ciudad, @Model.DireccionEntrega?.Estado, CP @Model.DireccionEntrega?.CodigoPostal</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-4 bg-light">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold mb-3">Resumen de Pago</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>$@Model.Subtotal.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Envío</span>
                        <span>$@Model.CostoEnvio.ToString("N2")</span>
                    </div>
                    @if (Model.Impuestos > 0)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>Impuestos</span>
                            <span>$@Model.Impuestos.ToString("N2")</span>
                        </div>
                    }
                    <hr>
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">Total Pagado</h5>
                        <h4 class="fw-bold mb-0 text-primary">$@Model.Total.ToString("N2")</h4>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm border-start border-4 @(Model.EstadoPedido == "Cancelado" ? "border-danger" : "border-success") mb-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold mb-2">Estado del Pedido</h6>
                    <h5 class="fw-bold mb-0 text-dark">@Model.EstadoPedido</h5>
                </div>
            </div>

            @if (Model.Envio != null)
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h6 class="text-muted text-uppercase small fw-bold mb-3"><i class="fas fa-route text-primary me-2"></i>Seguimiento del Envío</h6>
                        
                        @if (!string.IsNullOrEmpty(Model.Envio.NumeroGuia))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3 bg-light p-2 rounded">
                                <div>
                                    <small class="text-muted d-block">Paquetería:</small>
                                    <span class="fw-bold">@Model.Envio.Paqueteria</span>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block">No. Guía:</small>
                                    <code class="text-primary fw-bold fs-6">@Model.Envio.NumeroGuia</code>
                                </div>
                            </div>
                        }

                        <h6 class="fw-bold text-dark mt-4 mb-3">Línea de Tiempo</h6>
                        
                        <div class="tracking-timeline position-relative ps-4 mb-3 pb-2">
                            <!-- Helper stroke for vertical line -->
                            <div class="position-absolute h-100 border-start border-2 border-primary" style="left: 0.5rem; top: 0.5rem; z-index: 1;"></div>
                            
                            @if (Model.Envio.HistorialEnvios != null && Model.Envio.HistorialEnvios.Any())
                            {
                                var historyOrdered = Model.Envio.HistorialEnvios.OrderByDescending(h => h.Fecha).ToList();
                                for (int i = 0; i < historyOrdered.Count; i++)
                                {
                                    var hist = historyOrdered[i];
                                    bool isLast = i == 0; // First in descending is the latest status
                                    string icon = "fa-truck text-white";
                                    string bgClass = isLast ? "bg-primary shadow" : "bg-secondary";

                                    if(hist.Estado == "Entregado") icon = "fa-check text-white";
                                    if(hist.Estado == "Preparando") icon = "fa-box text-white";
                                    
                                    <div class="position-relative mb-4">
                                        <div class="position-absolute rounded-circle @bgClass d-flex justify-content-center align-items-center" style="width: 30px; height: 30px; left: -2.3rem; top: 0; z-index: 2;">
                                            <i class="fas @icon small"></i>
                                        </div>
                                        <div class="ms-1">
                                            <h6 class="fw-bold mb-1 @(isLast ? "text-primary" : "text-dark")">@hist.Estado</h6>
                                            <div class="small text-muted mb-1"><i class="far fa-clock me-1"></i>@hist.Fecha.ToString("dd MMM yyyy, HH:mm")</div>
                                            @if (!string.IsNullOrEmpty(hist.Ubicacion))
                                            {
                                                <div class="small fw-600 bg-light d-inline-block px-2 py-1 rounded text-muted mt-1">@hist.Ubicacion</div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="position-relative">
                                    <div class="position-absolute rounded-circle bg-secondary d-flex justify-content-center align-items-center" style="width: 30px; height: 30px; left: -2.3rem; top: 0; z-index: 2;">
                                        <i class="fas fa-box text-white small"></i>
                                    </div>
                                    <div class="ms-1">
                                        <h6 class="fw-bold mb-1 text-dark">Preparando Pedido</h6>
                                        <div class="small text-muted mb-1">Tu envío será procesado pronto.</div>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        @if (!string.IsNullOrEmpty(Model.Envio.Notas))
                        {
                            <div class="alert alert-warning mb-0 p-2 small border-0 shadow-sm">
                                <i class="fas fa-exclamation-triangle me-1"></i> @Model.Envio.Notas
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
