@model RefWeb.Models.Producto
@{
    ViewData["Title"] = Model.Nombre;
    var relacionados = ViewBag.Relacionados as List<RefWeb.Models.Producto> ?? new();
}

@section Breadcrumbs {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb breadcrumb-modern">
            <li class="breadcrumb-item"><a asp-action="Index">Tienda</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoriaId="@Model.CategoriaId">@Model.Categoria?.Nombre</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Nombre</li>
        </ol>
    </nav>
}

<div class="container animate-fade-in mb-5">

    <div class="row g-5 align-items-start">
        <!-- Imagen -->
        <div class="col-lg-5">
            <div class="card card-modern border-0 shadow-sm p-4 text-center" style="min-height: 380px;">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" alt="@Model.Nombre"
                         class="img-fluid" style="max-height: 340px; object-fit: contain;">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted" style="min-height:340px">
                        <i class="fas fa-tools fa-6x opacity-10"></i>
                    </div>
                }

                @if (Model.Stock <= 0)
                {
                    <span class="badge bg-danger mt-3 px-3 py-2 fs-6">Sin Stock</span>
                }
                else if (Model.Stock <= Model.StockMinimo)
                {
                    <span class="badge bg-warning text-dark mt-3 px-3 py-2">Últimas @Model.Stock unidades</span>
                }
            </div>
        </div>

        <!-- Info -->
        <div class="col-lg-7">
            <span class="badge bg-primary-soft text-primary fw-bold mb-3">@Model.Categoria?.Nombre</span>
            <h1 class="fw-bold text-dark mb-2" style="font-size: 1.9rem;">@Model.Nombre</h1>
            <p class="text-muted small mb-1">SKU: <strong>@Model.CodigoSKU</strong></p>

            <div class="my-4">
                <span class="display-5 fw-800 text-primary">$@Model.Precio.ToString("N2")</span>
                <span class="text-muted ms-2 small">MXN</span>
            </div>

            <p class="text-secondary lh-lg mb-4">@(Model.Descripcion ?? "Sin descripción disponible.")</p>

            @if (Model.Stock > 0)
            {
                <!-- Cantidad + Agregar -->
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="input-group" style="max-width: 130px;">
                        <button class="btn btn-outline-secondary" type="button" id="btnMinus">
                            <i class="fas fa-minus"></i>
                        </button>
                        <input type="number" id="inputCantidad" class="form-control text-center fw-bold"
                               value="1" min="1" max="@Model.Stock">
                        <button class="btn btn-outline-secondary" type="button" id="btnPlus">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                    <button id="btnAgregarCarrito"
                            class="btn btn-primary-modern btn-lg px-5 fw-bold shadow-sm flex-grow-1"
                            onclick="agregarAlCarrito()">
                        <i class="fas fa-shopping-cart me-2"></i>Añadir al Carrito
                    </button>
                </div>
                <p class="small text-muted"><i class="fas fa-box me-1"></i> @Model.Stock unidades disponibles</p>
            }
            else
            {
                <div class="alert alert-danger d-flex align-items-center gap-2">
                    <i class="fas fa-times-circle"></i> Este producto está agotado actualmente.
                </div>
            }

            <!-- Info adicional -->
            <div class="d-flex gap-4 mt-3 flex-wrap">
                <div class="text-center">
                    <i class="fas fa-shipping-fast text-primary d-block fs-4 mb-1"></i>
                    <span class="small text-muted">Envío a todo México</span>
                </div>
                <div class="text-center">
                    <i class="fas fa-shield-alt text-primary d-block fs-4 mb-1"></i>
                    <span class="small text-muted">Garantía de calidad</span>
                </div>
                <div class="text-center">
                    <i class="fas fa-undo text-primary d-block fs-4 mb-1"></i>
                    <span class="small text-muted">Devolución fácil</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Productos Relacionados -->
    @if (relacionados.Any())
    {
        <hr class="my-5 opacity-10">
        <h4 class="fw-bold mb-4">También te puede interesar</h4>
        <div class="row g-4">
            @foreach (var rel in relacionados)
            {
                <div class="col-md-6 col-lg-3">
                    <div class="glass-card product-card d-flex flex-column h-100 overflow-hidden">
                        <a asp-action="Detalle" asp-route-id="@rel.Id" class="text-decoration-none">
                            <div class="bg-light text-center p-3" style="height: 160px;">
                                @if (!string.IsNullOrEmpty(rel.ImagenUrl))
                                {
                                    <img src="@rel.ImagenUrl" alt="@rel.Nombre"
                                         class="h-100 w-100" style="object-fit:contain;">
                                }
                                else
                                {
                                    <i class="fas fa-tools fa-3x text-muted opacity-25 mt-4"></i>
                                }
                            </div>
                        </a>
                        <div class="card-body p-3 d-flex flex-column">
                            <a asp-action="Detalle" asp-route-id="@rel.Id"
                               class="fw-bold text-dark text-decoration-none small mb-2">@rel.Nombre</a>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="fw-800 text-primary">$@rel.Precio.ToString("N2")</span>
                                <button class="btn btn-sm btn-primary rounded-circle p-0"
                                        style="width:36px;height:36px;"
                                        onclick="CartManager.add(@rel.Id, '@rel.Nombre', @rel.Precio, '@rel.ImagenUrl')"
                                        title="Añadir al carrito">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
    // Cantidad controls
    document.getElementById('btnMinus').addEventListener('click', () => {
        const input = document.getElementById('inputCantidad');
        if (parseInt(input.value) > 1) input.value = parseInt(input.value) - 1;
    });
    document.getElementById('btnPlus').addEventListener('click', () => {
        const input = document.getElementById('inputCantidad');
        const max = parseInt(input.max);
        if (parseInt(input.value) < max) input.value = parseInt(input.value) + 1;
    });

    function agregarAlCarrito() {
        const cantidad = parseInt(document.getElementById('inputCantidad').value) || 1;
        for (let i = 0; i < cantidad; i++) {
            CartManager.add(@Model.Id, '@Model.Nombre.Replace("'", "\\'")', @Model.Precio, '@(Model.ImagenUrl ?? "")');
        }
        Swal.fire({
            icon: 'success',
            title: '¡Agregado!',
            text: `${cantidad} × @Model.Nombre añadido al carrito.`,
            timer: 1800,
            showConfirmButton: false,
            position: 'top-end',
            toast: true
        });
    }

    $(document).ready(function() {
        CartManager.updateBadge();
    });
</script>
}
