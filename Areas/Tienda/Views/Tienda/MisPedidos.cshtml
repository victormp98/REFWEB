@model IEnumerable<RefWeb.Models.Pedido>
@{
    ViewData["Title"] = "Mis Pedidos";
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-5 mt-5">
        <h2 class="fw-bold mb-0">Mis Pedidos</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-primary">Volver a la Tienda</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center">
            <i class="fas fa-history fa-4x text-muted mb-3"></i>
            <h4>No tienes pedidos registrados</h4>
            <p class="text-muted">Cuando realices una compra, aquí aparecerán todos tus pedidos.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Folio</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@p.Id.ToString("D6")</td>
                                <td>@p.FechaPedido.ToShortDateString()</td>
                                <td class="fw-bold text-primary">$@p.Total.ToString("N2")</td>
                                <td>
                                    @switch (p.EstadoPedido)
                                    {
                                        case "Pendiente": 
                                            <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Pendiente</span> 
                                            break;
                                        case "Pagado": 
                                            <span class="badge bg-info"><i class="fas fa-check me-1"></i>Pagado</span> 
                                            break;
                                        case "En Proceso":
                                            <span class="badge bg-warning"><i class="fas fa-box me-1"></i>En Proceso</span>
                                            <div class="small text-muted mt-1"><i class="fas fa-info-circle me-1"></i>Preparando tu paquete</div>
                                            break;
                                        case "Enviado": 
                                            <span class="badge bg-primary"><i class="fas fa-truck me-1"></i>Enviado</span> 
                                            <div class="small text-muted mt-1">
                                                <i class="fas fa-info-circle me-1"></i>Guía: <strong>@p.Envio?.NumeroGuia</strong> (@p.Envio?.Paqueteria)
                                            </div>
                                            break;
                                        case "Entregado": 
                                            <span class="badge bg-success"><i class="fas fa-box-open me-1"></i>Entregado</span> 
                                            break;
                                        case "Cancelado": 
                                            <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Cancelado</span> 
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@p.EstadoPedido</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("DetallePedido", new { id = p.Id })" class="btn btn-sm btn-primary shadow-sm me-1">
                                        <i class="fas fa-eye me-1"></i>Detalles
                                    </a>
                                    @if (p.EstadoPedido == "Enviado")
                                    {
                                        <form asp-action="ConfirmarEntrega" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="pedidoId" value="@p.Id" />
                                            <button type="submit" class="btn btn-sm btn-success shadow-sm"
                                                    onclick="return confirm('¿Confirmar que recibió el pedido #@p.Id.ToString("D6")? Esta acción no puede deshacerse.')">
                                                <i class="fas fa-check-double me-1"></i>Confirmé que lo recibí
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* UX-05: Paginación *@
        @if (totalPaginas > 1)
        {
            <nav class="mt-4 d-flex justify-content-center" aria-label="Paginación de pedidos">
                <ul class="pagination">
                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("MisPedidos", new { pagina = paginaActual - 1 })">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPaginas; i++)
                    {
                        <li class="page-item @(i == paginaActual ? "active" : "")">
                            <a class="page-link" href="@Url.Action("MisPedidos", new { pagina = i })">@i</a>
                        </li>
                    }
                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("MisPedidos", new { pagina = paginaActual + 1 })">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
