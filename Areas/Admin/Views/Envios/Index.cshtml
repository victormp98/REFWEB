@model IEnumerable<RefWeb.Models.Pedido>
@{
    ViewData["Title"] = "Gestión de Envíos";
}

<div class="animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-1">Gestión de Envíos</h1>
            <p class="text-muted mb-0">Administra el cumplimiento de pedidos y números de guía.</p>
        </div>
        <div class="icon-box icon-box-primary-soft">
            <i class="fas fa-truck-loading"></i>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="glass-card bg-success border-0 text-white p-3 mb-4 d-flex align-items-center animate-fade-in shadow-sm">
            <i class="fas fa-check-circle me-3 fs-4"></i>
            <div>@TempData["Success"]</div>
            <button type="button" class="btn-close btn-close-white ms-auto shadow-none" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="glass-card bg-danger border-0 text-white p-3 mb-4 d-flex align-items-center animate-fade-in shadow-sm">
            <i class="fas fa-exclamation-circle me-3 fs-4"></i>
            <div>@TempData["Error"]</div>
            <button type="button" class="btn-close btn-close-white ms-auto shadow-none" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="glass-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Folio y Fecha</th>
                        <th>Cliente</th>
                        <th>Estado</th>
                        <th>Paquetería</th>
                        <th>Guía</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark d-block">#@item.Id.ToString("D6")</span>
                                <span class="small text-muted">@item.FechaPedido.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-soft rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                        <i class="fas fa-user text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.Cliente?.Nombre @item.Cliente?.Apellidos</div>
                                        <div class="small text-muted">@item.Cliente?.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @switch (item.EstadoPedido)
                                {
                                    case "Pagado":
                                        <span class="badge bg-info-soft"><i class="fas fa-wallet me-1"></i>Pagado</span>
                                        break;
                                    case "En Proceso":
                                        <span class="badge bg-warning-soft text-dark"><i class="fas fa-box me-1"></i>En Proceso</span>
                                        break;
                                    case "Enviado":
                                        <span class="badge bg-primary-soft"><i class="fas fa-truck me-1"></i>Enviado</span>
                                        break;
                                    case "Entregado":
                                        <span class="badge bg-success-soft"><i class="fas fa-check-circle me-1"></i>Entregado</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary-soft">@item.EstadoPedido</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Envio?.Paqueteria))
                                {
                                    <span class="fw-bold text-dark">@item.Envio.Paqueteria</span>
                                }
                                else
                                {
                                    <span class="text-muted small italic opacity-50">Pendiente</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Envio?.NumeroGuia))
                                {
                                    <code class="bg-light px-2 py-1 rounded text-primary fw-bold">@item.Envio.NumeroGuia</code>
                                }
                                else
                                {
                                    <span class="text-muted small italic opacity-50">Sin asignar</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (item.EstadoPedido == "Pagado")
                                {
                                    <form asp-action="CambiarAEnProceso" method="post" class="d-inline me-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="pedidoId" value="@item.Id" />
                                        <button type="submit" class="btn btn-warning btn-sm px-3"
                                                title="Preparar el paquete">
                                            <i class="fas fa-box me-1"></i> Preparar
                                        </button>
                                    </form>
                                }
                                @if (item.EstadoPedido == "Pagado" || item.EstadoPedido == "En Proceso")
                                {
                                    <a asp-action="AsignarGuia" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm px-3"
                                       title="Asignar guía de envío">
                                        <i class="fas fa-barcode me-1"></i> Asignar Guía
                                    </a>

                                    <form asp-action="CancelarPedido" method="post" class="d-inline ms-1" 
                                          onsubmit="return confirm('¿Estás seguro de que deseas cancelar el pedido #@item.Id.ToString("D6")? El stock será devuelto al inventario y esta acción no se puede deshacer.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="pedidoId" value="@item.Id" />
                                        <input type="hidden" name="motivo" value="Cancelado desde el panel de administración" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm px-3" title="Cancelar Pedido">
                                            <i class="fas fa-ban me-1"></i> Cancelar
                                        </button>
                                    </form>
                                }
                                @if (item.EstadoPedido == "Enviado")
                                {
                                    <a asp-action="AsignarGuia" asp-route-id="@item.Id"
                                       class="btn btn-outline-secondary btn-sm px-3"
                                       title="Ver estado de envío">
                                        <i class="fas fa-truck me-1"></i> Ver Estado
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
