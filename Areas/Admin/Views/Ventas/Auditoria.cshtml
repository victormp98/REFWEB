@model IEnumerable<RefWeb.Models.Venta>
@{
    ViewData["Title"] = "Auditoría de Cancelaciones";
}

<div class="animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold text-danger mb-1"><i class="fas fa-shield-alt me-3"></i>Auditoría de Anulaciones</h1>
            <p class="text-muted mb-0">Registro histórico de transacciones marcadas como anuladas o devueltas en el Punto de Venta.</p>
        </div>
        <div class="icon-box icon-box-danger-soft">
            <i class="fas fa-user-shield"></i>
        </div>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="bg-light p-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-danger">Registro de Operaciones Anuladas</h6>
            <span class="badge bg-danger-soft text-danger border border-danger">@Model.Count() Registros Encontrados</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="tablaAuditoria">
                <thead>
                    <tr>
                        <th class="ps-4">Folio / Fecha Original</th>
                        <th>Vendedor</th>
                        <th>Anulado Por</th>
                        <th>Fecha de Anulación</th>
                        <th>Motivo Descrito</th>
                        <th class="text-end pe-4">Monto Afectado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-check-circle fa-3x text-success opacity-50 mb-3 d-block"></i>
                                Todo en orden. No existen transacciones anuladas.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var v in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@v.Folio</div>
                                    <div class="text-muted small">@v.Fecha.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border"><i class="fas fa-user me-1"></i> @(v.Usuario?.UserName ?? "-")</span>
                                </td>
                                <td>
                                    <span class="badge bg-danger-soft text-danger fw-bold"><i class="fas fa-user-shield me-1"></i> @(v.UsuarioCancela?.UserName ?? "Admin")</span>
                                </td>
                                <td>
                                    <span class="text-secondary small"><i class="far fa-clock me-1"></i> @(v.FechaCancelacion?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                                </td>
                                <td style="max-width: 200px;" class="text-wrap">
                                    <span class="text-muted small fst-italic">"@(v.MotivoCancelacion ?? "Sin motivo")"</span>
                                </td>
                                <td class="text-end pe-4">
                                    <span class="fw-800 text-danger">@v.Total.ToString("C")</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
