@model List<(Microsoft.AspNetCore.Identity.IdentityUser Usuario, string Rol, bool Bloqueado)>
@{
    ViewData["Title"] = "Gestión de Usuarios";
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
}

<div class="animate-fade-in">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex align-items-center mb-5">
        <div class="icon-box icon-box-primary me-4">
            <i class="fas fa-users fa-lg"></i>
        </div>
        <div>
            <h1 class="display-6 fw-bold text-dark mb-0">Gestión de Usuarios</h1>
            <p class="text-muted mb-0">Administra roles, accesos y contraseñas de los usuarios del sistema.</p>
        </div>
    </div>

    
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="glass-card p-3 text-center">
                <div class="fw-bold display-6 text-primary">@Model.Count</div>
                <div class="text-muted small">Total usuarios</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="glass-card p-3 text-center">
                <div class="fw-bold display-6 text-success">@Model.Count(u => !u.Bloqueado)</div>
                <div class="text-muted small">Activos</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="glass-card p-3 text-center">
                <div class="fw-bold display-6 text-danger">@Model.Count(u => u.Bloqueado)</div>
                <div class="text-muted small">Bloqueados</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="glass-card p-3 text-center">
                <div class="fw-bold display-6 text-warning">@roles.Count</div>
                <div class="text-muted small">Roles</div>
            </div>
        </div>
    </div>

    <!-- Barra de búsqueda de usuarios -->
    <div class="glass-card p-3 mb-4">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" id="buscarUsuario" class="form-control border-start-0 ps-0"
                           placeholder="Buscar por correo…" oninput="filtrarUsuarios()">
                </div>
            </div>
            <div class="col-md-4">
                <select id="filtroRol" class="form-select" onchange="filtrarUsuarios()">
                    <option value="">Todos los roles</option>
                    @foreach (var r in roles)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>
            <div class="col-md-3 text-md-end">
                <span id="conteoUsuarios" class="text-muted small"></span>
            </div>
        </div>
    </div>

    <div class="card card-modern border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tablaUsuarios" class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Usuario</th>
                            <th>Rol</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (usuario, rol, bloqueado) in Model)
                        {
                            <tr class="@(bloqueado ? "table-danger bg-opacity-25" : "")"
                                data-email="@usuario.Email?.ToLower()"
                                data-rol="@rol">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                             style="width: 40px; height: 40px; background: linear-gradient(135deg, #6366f1, #8b5cf6); font-size: 1rem; flex-shrink: 0;">
                                            @(usuario.Email?.FirstOrDefault().ToString().ToUpper() ?? "?")
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark small">@usuario.Email</div>
                                            <div class="text-muted" style="font-size: 0.7rem; font-family: monospace;">@usuario.Id[..8]…</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @{
                                        var badgeColor = rol switch {
                                            "Admin"    => "danger",
                                            "Gerente"  => "warning",
                                            "Vendedor" => "primary",
                                            "Cliente"  => "success",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@badgeColor rounded-pill px-3">@rol</span>
                                </td>
                                <td class="text-center">
                                    @if (bloqueado)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3"><i class="fas fa-lock me-1"></i>Bloqueado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3"><i class="fas fa-check me-1"></i>Activo</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        
                                        <button class="btn btn-outline-primary border-0" title="Cambiar Rol"
                                                onclick="abrirModalRol('@usuario.Id', '@usuario.Email', '@rol')">
                                            <i class="fas fa-user-tag"></i>
                                        </button>

                                        
                                        <form asp-action="ToggleLock" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@usuario.Id" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn border-0 @(bloqueado ? "btn-outline-success" : "btn-outline-warning")"
                                                    title="@(bloqueado ? "Desbloquear" : "Bloquear")">
                                                <i class="fas @(bloqueado ? "fa-lock-open" : "fa-lock")"></i>
                                            </button>
                                        </form>

                                        
                                        <button class="btn btn-outline-secondary border-0" title="Resetear Contraseña"
                                                onclick="abrirModalPassword('@usuario.Id', '@usuario.Email')">
                                            <i class="fas fa-key"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalRol" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="fas fa-user-tag me-2 text-primary"></i>Cambiar Rol</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CambiarRol" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="rolUserId" />
                <div class="modal-body">
                    <p class="text-muted mb-3">Usuario: <strong id="rolUserEmail"></strong></p>
                    <label class="form-label fw-bold small text-uppercase">Nuevo Rol</label>
                    <select name="nuevoRol" class="form-select" id="selectRol">
                        @foreach (var r in roles)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="modalPassword" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="fas fa-key me-2 text-warning"></i>Restablecer Contraseña</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="pwdUserId" />
                <div class="modal-body">
                    <p class="text-muted mb-3">Usuario: <strong id="pwdUserEmail"></strong></p>
                    <div class="alert alert-warning small">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        El usuario deberá iniciar sesión con esta nueva contraseña.
                    </div>
                    <label class="form-label fw-bold small text-uppercase">Nueva Contraseña</label>
                    <div class="input-group">
                        <input type="password" name="nuevaPassword" id="nuevaPassword" class="form-control"
                               placeholder="Mínimo 6 caracteres" minlength="6" required />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePwd()">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning px-4">Restablecer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Filtro de usuarios en tiempo real ──────────────────────────────
        function filtrarUsuarios() {
            const txt  = document.getElementById('buscarUsuario').value.toLowerCase();
            const rol  = document.getElementById('filtroRol').value.toLowerCase();
            const filas = document.querySelectorAll('#tablaUsuarios tbody tr');
            let visibles = 0;

            filas.forEach(fila => {
                const email    = (fila.dataset.email || '').toLowerCase();
                const rolFila  = (fila.dataset.rol   || '').toLowerCase();

                const okTxt = !txt || email.includes(txt);
                const okRol = !rol || rolFila === rol;

                if (okTxt && okRol) { fila.style.display = ''; visibles++; }
                else                { fila.style.display = 'none'; }
            });

            const total = filas.length;
            document.getElementById('conteoUsuarios').textContent =
                txt || rol ? `Mostrando ${visibles} de ${total}` : `${total} usuarios`;
        }

        window.addEventListener('DOMContentLoaded', () => filtrarUsuarios());

        function abrirModalRol(userId, email, rolActual) {
            document.getElementById('rolUserId').value = userId;
            document.getElementById('rolUserEmail').textContent = email;
            const select = document.getElementById('selectRol');
            for (let opt of select.options) {
                opt.selected = opt.value === rolActual;
            }
            new bootstrap.Modal(document.getElementById('modalRol')).show();
        }

        function abrirModalPassword(userId, email) {
            document.getElementById('pwdUserId').value = userId;
            document.getElementById('pwdUserEmail').textContent = email;
            document.getElementById('nuevaPassword').value = '';
            new bootstrap.Modal(document.getElementById('modalPassword')).show();
        }

        function togglePwd() {
            const input = document.getElementById('nuevaPassword');
            const icon  = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}
