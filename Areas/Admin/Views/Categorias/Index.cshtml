@model IEnumerable<RefWeb.Models.Categoria>
@{
    ViewData["Title"] = "Categorías";
}

<div class="animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-1">Categorías</h1>
            <p class="text-muted mb-0">Organiza el catálogo de productos por categoría.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-lg">
            <i class="fas fa-plus me-2"></i> Nueva Categoría
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="glass-card p-3 mb-4 d-flex align-items-center animate-fade-in" style="background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.2);">
            <i class="fas fa-check-circle text-success me-3 fs-4"></i>
            <span class="fw-medium">@TempData["Success"]</span>
        </div>
    }

    <div class="row g-4">
        @foreach (var cat in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="glass-card p-4 h-100 @(!cat.Activo ? "opacity-50" : "")">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="icon-box icon-box-primary-soft">
                            <i class="fas fa-tag"></i>
                        </div>
                        @if (cat.Activo)
                        {
                            <span class="badge bg-success-soft">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-danger-soft">Inactiva</span>
                        }
                    </div>

                    <h5 class="fw-bold text-dark mb-1">@cat.Nombre</h5>
                    <p class="text-muted small mb-3">@(cat.Descripcion ?? "Sin descripción")</p>

                    <div class="d-flex align-items-center text-muted small mb-4">
                        <i class="fas fa-boxes me-2 text-primary"></i>
                        <span>@(cat.Productos?.Count ?? 0) productos asociados</span>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="fas fa-pencil-alt me-1"></i> Editar
                        </a>
                        <form asp-action="Toggle" asp-route-id="@cat.Id" method="post" class="flex-fill">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm w-100 @(cat.Activo ? "btn-outline-danger" : "btn-outline-success")">
                                @if (cat.Activo)
                                {
                                    <i class="fas fa-eye-slash me-1"></i><span>Desactivar</span>
                                }
                                else
                                {
                                    <i class="fas fa-eye me-1"></i><span>Activar</span>
                                }
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="glass-card p-5 text-center">
                    <div class="opacity-25 mb-4">
                        <i class="fas fa-tags fa-4x"></i>
                    </div>
                    <h5 class="fw-bold">No hay categorías registradas</h5>
                    <p class="text-muted">Crea la primera para comenzar a organizar el catálogo.</p>
                    <a asp-action="Create" class="btn btn-primary mt-2">
                        <i class="fas fa-plus me-2"></i> Crear Categoría
                    </a>
                </div>
            </div>
        }
    </div>
</div>
