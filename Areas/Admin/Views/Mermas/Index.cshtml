@model IEnumerable<RefWeb.Models.Merma>

@{
    ViewData["Title"] = "Historial de Mermas";
}

@section Breadcrumbs {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb breadcrumb-modern">
            <li class="breadcrumb-item"><a asp-area="Tienda" asp-controller="Tienda" asp-action="Index">Tienda</a></li>
            <li class="breadcrumb-item active" aria-current="page">Mermas</li>
        </ol>
    </nav>
}

<div class="animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 fw-bold text-dark mb-1">Historial de Mermas</h1>
            <p class="text-muted mb-0">Registros de pérdida de inventario y ajustes de stock.</p>
        </div>
        <div class="icon-box icon-box-primary-soft" style="background: rgba(239, 68, 68, 0.1); color: var(--danger);">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
    </div>

    <div class="mb-4 d-flex justify-content-end">
        <a asp-action="Create" class="btn btn-primary shadow-lg" style="background: linear-gradient(135deg, var(--danger), #dc2626);">
            <i class="fas fa-plus me-2"></i> Reportar Merma
        </a>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Fecha</th>
                        <th>Producto</th>
                        <th class="text-center">Cantidad</th>
                        <th>Tipo</th>
                        <th>Responsable</th>
                        <th class="text-end pe-4">Motivo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="bg-light px-2 py-1 rounded small fw-bold text-muted">
                                    @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Producto?.Nombre</div>
                                <div class="text-muted x-small">SKU: @item.ProductoId</div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-danger-soft fw-800">
                                    -@item.Cantidad
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-warning-soft">
                                    @item.TipoMerma
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-soft rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
                                        <i class="fas fa-user text-primary small"></i>
                                    </div>
                                    <span class="small fw-medium">@item.Responsable?.UserName</span>
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <span class="text-muted small italic">"@item.Motivo"</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
